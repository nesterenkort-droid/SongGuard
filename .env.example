# ── Скопируйте этот файл в .env и заполните значения ──
# cp .env.example .env

# Окружение: development | production
APP_ENV=development

# Секретный ключ для подписи сессий. В проде замените на случайную строку:
#   openssl rand -hex 32
SECRET_KEY=change-me-in-production

# ── База данных (значения по умолчанию совпадают с docker-compose) ──
POSTGRES_USER=trackguard
POSTGRES_PASSWORD=trackguard
POSTGRES_DB=trackguard
DATABASE_URL=postgresql+asyncpg://trackguard:trackguard@postgres:5432/trackguard

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Telegram ──
# Токен от @BotFather:
TELEGRAM_BOT_TOKEN=
# Username бота без @ (нужен для ссылок-входа), например: trackguard_bot
TELEGRAM_BOT_USERNAME=
# ID администраторов через запятую (узнать свой ID: @userinfobot).
# Эти пользователи входят без инвайта и сразу получают роль админа:
ADMIN_TG_IDS=

# ── Spotify (можно оставить пустым — импорт по iTunes работает без ключей) ──
# Создать приложение: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Троттлинг Spotify (dev-приложение имеет малую квоту, окно 30 сек):
# интервал между запросами; 429/Retry-After обрабатывается всегда.
SPOTIFY_MIN_INTERVAL_SECONDS=1.0
# Размер страницы альбомов (макс 50; на некоторых сетях снизьте, напр. до 5):
SPOTIFY_ALBUMS_PAGE_LIMIT=50

# ── Веб / сессии ──
# Публичный адрес сайта (для формирования ссылок). Локально:
BASE_URL=http://localhost:8080

# ── Публикация nginx на хосте ──
# Локально порт 80 часто занят — используйте 8080. На проде поставьте 80.
NGINX_HTTP_PORT=8080
